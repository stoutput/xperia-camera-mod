<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <uses-permission android:name="android.permission.WRITE_SETTINGS" />
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS" />

    <application
        android:label="SonyCameraXposed"
        android:allowBackup="false"
        android:theme="@style/Theme.SonyCameraXposed">

        <activity
            android:name=".SettingsActivity"
            android:exported="true"
            android:label="Sony Camera Unlocker">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name=".PrefsProvider"
            android:authorities="com.xperia.cameraxposed.prefs"
            android:exported="true" />

        <meta-data android:name="xposedmodule" android:value="true" />
        <meta-data android:name="xposedminversion" android:value="82" />
        <meta-data android:name="xposeddescription"
            android:value="Injects Sony EXCAL vendor tags into all Camera2 API apps. Per-app profiles supported." />
        <meta-data android:name="xposedscope" android:resource="@array/xposed_scope" />

    </application>
</manifest>
