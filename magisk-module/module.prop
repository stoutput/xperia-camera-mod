id=sony-camera-unlock
name=Sony Camera2 API Unlocker
version=v2.0
versionCode=2
author=SonyCameraX Project
description=Injects Sony vendor tags (Creative Looks, Eye AF, Scene Detection, MFNR, HDR, Cinema Profiles) into ALL 3rd party Camera2 API apps automatically. No custom app needed. Configure via /data/local/tmp/sony-camera-shim.conf
